# =============================================
# SUPABASE EDGE FUNCTIONS — Environment Variables
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# =============================================

# Supabase (auto-injected in Edge Functions — no need to set manually)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Custom JWT secret — use a strong random string
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars

# Paystack — get from dashboard.paystack.com → Settings → API Keys
# Use live key for production, test key for development
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# Africa's Talking (for SMS/WhatsApp)
AT_API_KEY=your_africas_talking_api_key
AT_USERNAME=your_at_username
AT_SENDER_ID=SUSU

# Frontend URL (for Paystack callback and SMS links)
FRONTEND_URL=https://your-app.vercel.app
