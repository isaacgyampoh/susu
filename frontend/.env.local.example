# =============================================
# NEXT.JS FRONTEND — Environment Variables
# Copy to .env.local and fill in your values
# Set these in Vercel: Project → Settings → Environment Variables
# =============================================

# Supabase project URL (found in Supabase Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your deployed frontend URL (used by Paystack callback)
NEXT_PUBLIC_FRONTEND_URL=https://your-app.vercel.app
